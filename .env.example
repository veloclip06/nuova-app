# ---------------------------------------------------------------------------
# Cockpit EPR — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# Supabase (region: EU) --------------------------------------------------------
# Project URL and anon key are public (RLS-enforced, safe for the browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY. Bypasses RLS. Used by scripts/validate-rules.ts
# (seeding countries) and trusted server jobs. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostHog (analytics + checker funnel) ----------------------------------------
# EU host keeps analytics data in the EU region (§9 / GDPR).
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Resend (transactional email + deadline reminders) ---------------------------
RESEND_API_KEY=re_your_api_key
RESEND_FROM=Cockpit EPR <no-reply@your-domain.eu>

# Stripe (annual subscriptions: Essenziale 149€, Completo 249€) ---------------
# Mock placeholders until the Stripe account exists — every value below has a
# step in STRIPE_SETUP.md. Swapping in real values requires no code changes.
# Secret key — SERVER ONLY.
STRIPE_SECRET_KEY=sk_test_mock
# Webhook signing secret for /api/stripe/webhook (from the Stripe dashboard
# or `stripe listen`).
STRIPE_WEBHOOK_SECRET=whsec_mock
# The two annual price IDs (public: used to map plans, not secrets).
NEXT_PUBLIC_STRIPE_PRICE_ESSENZIALE=price_mock_essenziale
NEXT_PUBLIC_STRIPE_PRICE_COMPLETO=price_mock_completo

# App -------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Secret guarding the Vercel Cron deadline-reminder endpoint (§7).
CRON_SECRET=change-me
